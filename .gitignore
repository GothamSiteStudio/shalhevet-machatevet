# ============================================================
# .gitignore - שלהבת מחטבת אפליקציה
# ============================================================
# ⚠️  קבצים אלו לא יעלו לגיט לעולם - מכילים מידע סודי!
# ============================================================

# ─── קבצי סביבה (.env) ─────────────────────────────────────
# NEVER commit these - they contain secrets!
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.*.local
*.env

# ─── מסד הנתונים (db.json) ─────────────────────────────────
# מכיל מידע אישי של משתמשים - לא להעלות!
backend/db.json

# ─── node_modules ──────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build outputs ──────────────────────────────────────────
.next/
out/
dist/
build/
.expo/
**/.expo/
*.exp.json

# ─── Expo / React Native ───────────────────────────────────
shalhevet-app/.expo/
shalhevet-app/android/
shalhevet-app/ios/
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision
*.cer
google-services.json
GoogleService-Info.plist

# ─── קבצי מערכת ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── עורכי קוד ─────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── קבצי Cline / AI assistant ──────────────────────────────
.clinerules/
.cursorrules

# ─── קבצי מדיה גדולים ──────────────────────────────────────
*.mp4
*.mov
*.avi
*.mkv

# ─── כלי CI/CD ─────────────────────────────────────────────
.vercel
.netlify

# ─── מפתחות API וסודות נוספים ──────────────────────────────
*.pem
*.key
*.cert
secrets/
credentials/

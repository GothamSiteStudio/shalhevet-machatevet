# ============================================================
# .env.example - קובץ דוגמה להגדרות סביבה
# ============================================================
# 📋 הוראות:
#   1. העתיקי קובץ זה ל-.env  →  cp .env.example .env
#   2. מלאי את הערכים האמיתיים בקובץ .env
#   3. לעולם אל תעלי את .env לגיט!
# ============================================================

# ─── שרת ────────────────────────────────────────────────────
PORT=5000

# ─── JWT Secret ─────────────────────────────────────────────
# צרי מחרוזת ארוכה ואקראית! לדוגמה:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_STRING

# ─── כתובת האפליקציה ─────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── נתוני חשבון המאמנת (לצורך seed בלבד) ───────────────────
# ⚠️  שנה/י את הסיסמה לאחר ה-seed הראשון!
COACH_EMAIL=coach@example.com
COACH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
COACH_NAME=שם המאמנת
COACH_PHONE=05X-XXXXXXX

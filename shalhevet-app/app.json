{
  "expo": {
    "name": "שלהבת מחטבת",
    "slug": "shalhevet-mehatevet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#111111",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shalhevet.mehatevet",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#111111"
      },
      "package": "com.shalhevet.mehatevet",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "האפליקציה צריכה גישה לגלריה לצילום ארוחות"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "האפליקציה צריכה גישה לגלריה כדי לשמור עבורך תפריטים ותמונות.",
          "savePhotosPermission": "האפליקציה שומרת את התפריט המעוצב לגלריה שלך."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "4532fbf5-0158-413c-8711-a517ffd55583"
      }
    },
    "owner": "hashem1"
  }
}
